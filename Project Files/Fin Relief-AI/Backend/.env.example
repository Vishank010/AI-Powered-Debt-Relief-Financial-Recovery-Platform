# Rename this file to .env and fill in real values

# Secret key used to sign JWT tokens (use any long random string)
SECRET_KEY=change-this-to-a-long-random-secret-key

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini API key (get one at https://aistudio.google.com/app/apikey)
# If left blank, the app automatically falls back to rule-based logic
GEMINI_API_KEY=

# Database
DATABASE_URL=sqlite:///./finrelief.db
